---
title: ""
description: "Crónicas, literatura, memoria y voces que escriben cuando la ciudad duerme."
permalink: /index.html
---
{% extends "layouts/base.njk" %}

{% block content %}
  <section class="home-hero shell" aria-labelledby="home-title">
    <p class="eyebrow">Diario de vigilia</p>
    <h1 id="home-title">El insomnio de Gretel</h1>
    <p>{{ site.subtitle }}</p>
  </section>

  <section class="series-strip shell" aria-labelledby="series-title">
    <h2 id="series-title">Series:</h2>
    <div class="series-strip__links">
      {% for entry in seriesList.items | limit(3) %}
        <a href="{{ ('/series/' + entry.slug + '/') | url }}">{{ entry.name }}</a>
      {% endfor %}
    </div>
  </section>

  <section class="post-grid shell" aria-label="Entradas destacadas y recientes">
    {% set featured = collections.posts | selectattr('data.featured') | list %}
    {% set cards = featured if featured.length >= 4 else collections.posts %}
    {% for post in cards | limit(4) %}
      {% include "components/post-card.njk" %}
    {% endfor %}
  </section>

  <section class="home-more shell">
    <div>
      <p class="eyebrow">Últimas entradas</p>
      <h2>Lecturas para cuando la ciudad baja el volumen.</h2>
    </div>
    <a class="text-link" href="{{ '/a-z/' | url }}">Ver índice completo →</a>
  </section>
{% endblock %}
